# AFMX Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are prefixed with AFMX_

# ── Application ────────────────────────────────────────────────────────────────
AFMX_APP_NAME=AFMX
AFMX_APP_VERSION=1.0.0
AFMX_APP_ENV=development          # development | production
AFMX_DEBUG=true

# ── Server ─────────────────────────────────────────────────────────────────────
AFMX_HOST=0.0.0.0
AFMX_PORT=8100
AFMX_WORKERS=1                    # >1 requires Redis store backend
AFMX_API_PREFIX=/afmx

# ── Store Backend ───────────────────────────────────────────────────────────────
AFMX_STORE_BACKEND=memory         # memory | redis
AFMX_STATE_STORE_TTL_SECONDS=86400
AFMX_STATE_STORE_MAX_RECORDS=10000

# ── Redis (required when AFMX_STORE_BACKEND=redis) ──────────────────────────────
AFMX_REDIS_URL=redis://localhost:6379/3
AFMX_REDIS_KEY_PREFIX=afmx:exec:

# ── RBAC (Role-Based Access Control) ───────────────────────────────────────────
AFMX_RBAC_ENABLED=false
# AFMX_ADMIN_BOOTSTRAP_KEY=afmx_your_secure_random_value_here
AFMX_API_KEY_HEADER=X-AFMX-API-Key

# ── Audit Log ───────────────────────────────────────────────────────────────────
AFMX_AUDIT_ENABLED=true
AFMX_AUDIT_MAX_RECORDS=100000

# ── Webhooks ───────────────────────────────────────────────────────────────────
# AFMX_WEBHOOK_URL=https://your-server.com/afmx-events
AFMX_WEBHOOK_EVENTS=execution.completed,execution.failed
# AFMX_WEBHOOK_SECRET=your-hmac-signing-secret
AFMX_WEBHOOK_TIMEOUT_SECONDS=10
AFMX_WEBHOOK_RETRIES=3

# ── UI Dashboard ────────────────────────────────────────────────────────────────
AFMX_UI_ENABLED=true

# ── Observability ───────────────────────────────────────────────────────────────
AFMX_PROMETHEUS_ENABLED=true
AFMX_LOG_LEVEL=INFO
AFMX_LOG_EVENTS=true

# ── Rate Limiting ────────────────────────────────────────────────────────────────
AFMX_RATE_LIMIT_ENABLED=false
AFMX_RATE_LIMIT_PER_MINUTE=120
AFMX_RATE_LIMIT_BURST=30

# ── CORS ─────────────────────────────────────────────────────────────────────────
AFMX_CORS_ORIGINS=*
AFMX_CORS_ALLOW_CREDENTIALS=false

# ── Execution Engine Defaults ────────────────────────────────────────────────────
AFMX_DEFAULT_GLOBAL_TIMEOUT_SECONDS=300
AFMX_DEFAULT_NODE_TIMEOUT_SECONDS=30
AFMX_DEFAULT_MAX_PARALLELISM=10
AFMX_DEFAULT_RETRY_COUNT=3
AFMX_DEFAULT_RETRY_BACKOFF_SECONDS=1.0
AFMX_DEFAULT_RETRY_BACKOFF_MULTIPLIER=2.0
AFMX_DEFAULT_RETRY_MAX_BACKOFF_SECONDS=60.0
AFMX_DEFAULT_RETRY_JITTER=true
AFMX_MAX_CONCURRENT_EXECUTIONS=500
AFMX_CONCURRENCY_QUEUE_TIMEOUT_SECONDS=30

# ── Agentability Observability Integration ────────────────────────────────────
# Bridges AFMX execution into Agentability's agent intelligence platform.
# Requires: pip install agentability   (zero-overhead no-op when disabled)
#
# How it works:
#   - Every AFMX node   → Agentability Decision  (agent_id = matrix.node_name)
#   - Every AFMX matrix → Agentability Session   (session_id = execution_id)
#   - Circuit breaker   → Agentability Conflict  (ConflictType.RESOURCE_CONFLICT)
#   - Retry attempts    → LLM metrics retry_count field
#
# Offline mode (default): decisions written to local SQLite file — zero infra.
# Online mode: also set AFMX_AGENTABILITY_API_URL to push to the live platform.
#
# Start Agentability platform:
#   cd new_project/agentability/Agentability
#   AGENTABILITY_DB=agentability.db uvicorn platform.api.main:app --port 8000
AFMX_AGENTABILITY_ENABLED=false
AFMX_AGENTABILITY_DB_PATH=agentability.db
# AFMX_AGENTABILITY_API_URL=http://localhost:8000
# AFMX_AGENTABILITY_API_KEY=your-agentability-key
