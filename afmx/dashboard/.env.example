# AFMX Dashboard — environment variables
# Copy this file to .env and edit as needed.
# All variables are optional; defaults work for local development.

# ─── API target (backend) ──────────────────────────────────────
# URL of the AFMX server. The Vite dev server proxies all /afmx,
# /health, and /metrics requests to this target.
# Default: http://localhost:8100
VITE_API_URL=http://localhost:8100

# ─── Build base path ───────────────────────────────────────────
# Leave empty (/) for standard deployment.
# Set to a sub-path only if you serve the SPA under a prefix
# other than /afmx/ui (requires matching vite.config.ts base).
# VITE_BASE_PATH=/
