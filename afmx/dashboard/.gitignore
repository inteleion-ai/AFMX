# Dependencies
node_modules/
.pnp
.pnp.js

# Build output — goes into ../static/ (afmx/static/)
# We intentionally DO NOT gitignore ../static because afmx/static/
# may contain other non-SPA files (dashboard.html legacy, favicons).
# Only gitignore the Vite chunk output files specifically:
../static/assets/
../static/index.html

